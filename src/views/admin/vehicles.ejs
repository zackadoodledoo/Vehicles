<%- include("../partials/header") %>

<h1>Vehicle Management</h1>

<p>
  This section provides administrative visibility into vehicles listed on the platform.
</p>

<% if (!vehicles || vehicles.length === 0) { %>
  <p>No vehicles are currently available for management.</p>
<% } else { %>
    <div class="admin-actions">
        <a href="/admin/vehicles/new">Add New Vehicle</a>
    </div>

  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Year</th>
        <th>Mileage</th>
        <th>Price</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% vehicles.forEach(vehicle => { %>
        <tr>
          <td><%= vehicle.title %></td>
          <td><%= vehicle.year %></td>
          <td><%= vehicle.mileage.toLocaleString() %> miles</td>
          <td>$<%= vehicle.price.toLocaleString() %></td>
          <td class="admin-actions-cell">
            <a href="/admin/vehicles/<%= vehicle.id %>/edit">Edit</a>

            <form method="POST" action="/admin/vehicles/<%= vehicle.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this vehicle?');">
                <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include("../partials/footer") %>
