<h1>Login</h1>

<% if (error) { %>
  <p style="color: red;"><%= error %></p>
<% } %>

<form method="POST" action="/login">
  <div>
    <label for="email">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      required
    />
  </div>

  <div>
    <label for="password">Password</label>
    <input
      type="password"
      id="password"
      name="password"
      required
    />
  </div>

  <button type="submit">Login</button>
</form>
