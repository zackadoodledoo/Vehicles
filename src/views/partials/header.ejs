<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title || 'Less New Cars' %></title>

  <!-- CSS load order: base -> layout -> page-specific -> overrides -->
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/vehicles.css">
  <link rel="stylesheet" href="/css/reviews.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <header>
    <nav class="main-nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/vehicles">Vehicles</a>
      <a href="/contact">Contact</a>

      <% if (!user) { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } else { %>
        <a href="/dashboard">Dashboard</a>

        <% if (user.role === 'user') { %>
          <a href="/service-requests">My Service Requests</a>
        <% } %>

        <% if (user.role === 'employee') { %>
          <a href="/service-requests">Service Requests</a>
        <% } %>

        <% if (user.role === 'owner') { %>
          <a href="/admin">Admin</a>
        <% } %>

          <a href="/logout">Logout</a>
      <% } %>
</nav>


  </header>

  <main class="container" role="main">
