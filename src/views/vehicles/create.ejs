<%- include('../partials/header', { title: 'Create Vehicle', bodyClass: 'vehicles-page' }) %>

<main class="container">
  <h1>Create Vehicle</h1>

  <form action="/vehicles" method="post" class="vehicle-form">
    <label for="year">Year</label>
    <input id="year" name="year" type="number" required>

    <label for="make">Make</label>
    <input id="make" name="make" type="text" required>

    <label for="model">Model</label>
    <input id="model" name="model" type="text" required>

    <label for="price">Price</label>
    <input id="price" name="price" type="number" step="0.01">

    <label for="mileage">Mileage</label>
    <input id="mileage" name="mileage" type="number">

    <button type="submit">Create</button>
  </form>
</main>

<%- include('../partials/footer') %>
