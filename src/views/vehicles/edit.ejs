<%- include('../partials/header', { title: 'Edit Vehicle', bodyClass: 'vehicles-page' }) %>

<main class="container">
  <h1>Edit Vehicle</h1>

  <form action="/vehicles/<%= vehicle && vehicle.id ? vehicle.id : '' %>?_method=PUT" method="post" class="vehicle-form">
    <label for="year">Year</label>
    <input id="year" name="year" type="number" value="<%= vehicle && vehicle.year ? vehicle.year : '' %>" required>

    <label for="make">Make</label>
    <input id="make" name="make" type="text" value="<%= vehicle && vehicle.make ? vehicle.make : '' %>" required>

    <label for="model">Model</label>
    <input id="model" name="model" type="text" value="<%= vehicle && vehicle.model ? vehicle.model : '' %>" required>

    <label for="price">Price</label>
    <input id="price" name="price" type="number" step="0.01" value="<%= vehicle && typeof vehicle.price !== 'undefined' ? vehicle.price : '' %>">

    <label for="mileage">Mileage</label>
    <input id="mileage" name="mileage" type="number" value="<%= vehicle && vehicle.mileage ? vehicle.mileage : '' %>">

    <button type="submit">Save</button>
  </form>
</main>

<%- include('../partials/footer') %>
