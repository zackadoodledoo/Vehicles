<%- include('../partials/header', { title: 'Browse Vehicles', bodyClass: 'vehicles-page' }) %>

<section class="vehicles-list">
  <h1>Browse Vehicles</h1>

  <div class="cards-grid">
    <% if (vehicles && vehicles.length) { %>
      <% vehicles.forEach(function(vehicle) { %>
        <article class="card vehicle-card">
          <div class="image-wrap">
            <img src="<%= vehicle.image_url %>" alt="<%= vehicle.title %>" loading="lazy" onerror="this.src='/images/placeholder-vehicle.jpg'">

          </div>


          <div class="card-body">
            <h3 class="card-title">
              <a href="/vehicles/<%= vehicle.id %>"><%= (vehicle && vehicle.title) ? vehicle.title : 'Vehicle' %></a>
            </h3>
            <p class="card-meta">
              <span class="price">$<%= (vehicle && typeof vehicle.price !== 'undefined' && vehicle.price !== null) ? Number(vehicle.price).toLocaleString() : '0' %></span>
              <% if (vehicle && vehicle.mileage) { %>
                <span class="mileage"><%= Number(vehicle.mileage).toLocaleString() %> mi</span>
              <% } %>
            </p>
          </div>
        </article>
      <% }); %>
    <% } else { %>
      <p>No vehicles found.</p>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
