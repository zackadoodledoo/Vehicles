<%- include('../partials/header', { title: vehicle && vehicle.title ? vehicle.title : 'Vehicle', bodyClass: 'vehicles-page' }) %>

<article class="vehicle-detail card">
  <div class="image-wrap">
    <img class="card-img" src="<%= (vehicle && vehicle.image_url && vehicle.image_url.trim()) ? vehicle.image_url : '/images/placeholder-vehicle.jpg' %>" alt="<%= vehicle && vehicle.title ? vehicle.title : 'Vehicle' %>" loading="lazy" onerror="this.onerror=null;this.src='/images/placeholder-vehicle.jpg'">
  </div>


  <div class="card-body">
    <h2 class="card-title"><%= vehicle && vehicle.title ? vehicle.title : 'Vehicle' %></h2>
    <p class="card-meta">
      <span class="price">
        $<%= (vehicle && typeof vehicle.price !== 'undefined' && vehicle.price !== null) ? Number(vehicle.price).toLocaleString() : '0' %>
      </span>
      <% if (vehicle && vehicle.mileage) { %>
        <span class="mileage"><%= Number(vehicle.mileage).toLocaleString() %> mi</span>
      <% } %>
    </p>

    <!-- additional details -->
    <section class="details">
      <p><strong>Year</strong>: <%= vehicle && vehicle.year ? vehicle.year : '—' %></p>
      <p><strong>Description</strong>: <%= vehicle && vehicle.description ? vehicle.description : 'No description available.' %></p>
    </section>
  </div>
</article>

<%- include('../partials/footer') %>
